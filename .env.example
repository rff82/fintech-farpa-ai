# ─── Cloudflare Account ───────────────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_WORKERS_TOKEN=
CLOUDFLARE_AI_TOKEN=
CLOUDFLARE_MCP_TOKEN=

# ─── GitHub ───────────────────────────────────────────────────────────────────
GITHUB_TOKEN=

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_ID=

# ─── Auth.js (OAuth + session) ────────────────────────────────────────────────
AUTH_SECRET=                     # openssl rand -base64 32
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
NEXTAUTH_URL=https://health.farpa.ai

# ─── PubMed / RAG ─────────────────────────────────────────────────────────────
PUBMED_API_KEY=                  # optional — increases rate limit

# ─── Vision Simulator ─────────────────────────────────────────────────────────
CDHR1_ERC_BASELINE=1.0           # baseline ERC value
CDHR1_DECAY_RATE=0.035           # r_G per year

# ─── Local Development ────────────────────────────────────────────────────────
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
